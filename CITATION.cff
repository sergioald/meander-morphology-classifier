title: "Meander Morphology Classifier"
version: "0.2.1"
date-released: "2026-07-02"
repository-code: "https://github.com/sergioald/meander-morphology-classifier"
license: "MIT"
authors:
  - family-names: "Lopez Dubon"
    given-names: "Sergio"
  - family-names: "Sgarabotto"
    given-names: "Alessandro"
